rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return userExists() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }

    function isAdmin() {
      return signedIn() && myRole() == "admin";
    }

    function isDriver() {
      return signedIn() && myRole() == "chauffeur";
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);
      allow create: if isAdmin() || isSelf(userId);
      allow update: if isAdmin() || isSelf(userId);
      allow delete: if false;
    }

    match /camions/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /chauffeurs/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /voyages/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid);
      allow delete: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
    }

    // Nom utilisé par le projet actuel
    match /odometres/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Ancien nom accepté aussi pour éviter les blocages si une page l'utilise encore
    match /km_journalier/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /entretien/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /depenses/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /parametres/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
