rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return signedIn() && myUser().data.role == "admin"; }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /camions/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /chauffeurs/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /assignations/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /entretiens/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /depenses/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /voyages/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }
  }
}
