rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isDriver() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "chauffeur";
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);
      allow create: if isAdmin();
      allow update: if isAdmin() || isSelf(userId);
      // Suppression complète par Cloud Function deleteDriver seulement.
      allow delete: if false;
    }

    match /camions/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /chauffeurs/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin();
      // Suppression complète par Cloud Function deleteDriver seulement.
      allow delete: if false;
    }

    match /voyages/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid);
      allow delete: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
    }

    match /entretien/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /depenses/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // KM journalier sans stockage photo. La photo optionnelle est envoyée par email.
    match /odometres/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /parametres/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
