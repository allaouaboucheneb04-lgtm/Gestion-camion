rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function isDriver() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "chauffeur";
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create, update: if isAdmin() || request.auth.uid == userId;
      allow delete: if false;
    }

    match /camions/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /chauffeurs/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /voyages/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid);
      allow delete: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
    }

    match /odometres/{id} {
      allow read: if isAdmin() || isDriver();
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /affectations_journalieres/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /entretien/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /alertes_entretien/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /depenses/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /parametres/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
