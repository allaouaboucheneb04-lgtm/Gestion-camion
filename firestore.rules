rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function userExists() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function myRole() { return userExists() ? userDoc().data.role : null; }
    function isAdmin() { return signedIn() && myRole() == 'admin'; }
    function isDriver() { return signedIn() && myRole() == 'chauffeur'; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSelf(userId) && request.resource.data.role == resource.data.role);
    }

    match /camions/{id} { allow read: if signedIn(); allow create, update, delete: if isAdmin(); }
    match /chauffeurs/{id} { allow read: if isAdmin() || (isDriver() && resource.data.userId == request.auth.uid); allow create, update, delete: if isAdmin(); }
    match /voyages/{id} {
      allow read: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
      allow create: if isAdmin() || (isDriver() && request.resource.data.chauffeurId == request.auth.uid);
      allow update: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid && request.resource.data.chauffeurId == request.auth.uid && request.resource.data.createdBy == resource.data.createdBy);
      allow delete: if isAdmin() || (isDriver() && resource.data.chauffeurId == request.auth.uid);
    }
    match /entretien/{id} { allow read: if signedIn(); allow create, update, delete: if isAdmin(); }
    match /depenses/{id} { allow read: if signedIn(); allow create, update, delete: if isAdmin(); }
    match /parametres/{id} { allow read: if signedIn(); allow create, update: if isAdmin(); allow delete: if false; }
  }
}